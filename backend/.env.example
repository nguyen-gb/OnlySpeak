# App
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
DOCS_ENABLED=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://onlyspeak:CHANGE_ME@localhost:5432/onlyspeak
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Browser sessions. Generate with: openssl rand -hex 32
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_REUSE_GRACE_SECONDS=10
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=

# Exact web origins only; wildcards are rejected when cookies are enabled.
CORS_ORIGINS=["http://localhost:3000"]

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# AI free-talk provider
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
PROVIDER_TIMEOUT_SECONDS=20

# Text-to-speech
TTS_VOICE_A=en-US-GuyNeural
TTS_VOICE_B=en-US-AriaNeural
TTS_LINE_TIMEOUT_SECONDS=30
TTS_BATCH_TIMEOUT_SECONDS=120
TTS_CONCURRENCY=4

# Per-process abuse controls
AUTH_RATE_LIMIT_PER_MINUTE=30
CHAT_RATE_LIMIT_PER_MINUTE=20

# Every variable above also accepts an ONLYSPEAK_ prefix, for example:
# ONLYSPEAK_SECRET_KEY=...
